DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=qnyzhuayu.cn,www.qnyzhuayu.cn
DJANGO_CSRF_TRUSTED_ORIGINS=https://qnyzhuayu.cn,https://www.qnyzhuayu.cn

# Enable these only after HTTPS is correctly configured on the server.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False
